def assess_credit_risk(age, income, loan_amount, credit_score):
    
    if age < 18 or age > 70:
        return "Отказ: Возрастные ограничения"

    if loan_amount > income * 5:
        return "Отказ: Слишком большая сумма для данного дохода"

    if credit_score < 400:
        return "Отказ: Низкий кредитный рейтинг"
    elif 400 <= credit_score < 600:
        return "Одобрено с повышенной ставкой (Рисковый сегмент)"
    else:
        return "Одобрено: Надежный клиент"

if __name__ == "__main__":
    print("--- Система кредитного скоринга Кафедры цифровой экономики ---")
    user_data = {
        "age": 25,
        "income": 100000,
        "loan_amount": 300000,
        "credit_score": 650
    }
    result = assess_credit_risk(**user_data)
    print(f"Результат анализа: {result}")
